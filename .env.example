# Copia in .env e riempi con le credenziali del tuo progetto Supabase.
# Le trovi in: Supabase dashboard → Project Settings → API
# Senza queste, l'app usa i dati statici di src/data/proto-data.js (utile per dev offline).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry (opzionale). Senza DSN il client diventa no-op e gli errori finiscono solo in console.
# DSN lo trovi su sentry.io → Settings → Projects → [nolo] → Client Keys (DSN).
VITE_SENTRY_DSN=
VITE_RELEASE=

# Sentry source maps upload (server-side, build-time). Solo se vuoi caricare le source maps.
# Genera un token su sentry.io → Settings → Auth Tokens (scope: project:releases, project:write).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Analytics — tutti opzionali e env-gated. Senza chiave i provider sono no-op.
# Posthog: dashboard.posthog.com → Project settings → API Keys
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Microsoft Clarity: clarity.microsoft.com → Project → Setup
VITE_CLARITY_ID=

# Plausible: plausible.io → Sites → [il tuo dominio]
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_HOST=https://plausible.io

# Cloudinary (Phase 4). Cloud name + upload preset unsigned per uploads client-side.
# Crea un upload preset unsigned su cloudinary.com → Settings → Upload → Add upload preset.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Geoapify (autocomplete indirizzi) — myprojects.geoapify.com
VITE_GEOAPIFY_API_KEY=
